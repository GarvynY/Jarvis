* text=auto

# Files that may be executed directly on Linux must keep LF line endings.
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.service text eol=lf
*.timer text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Binary files should never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.db binary
*.sqlite binary
*.pem binary
*.p12 binary
*.pfx binary
